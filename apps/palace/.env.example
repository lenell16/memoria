# Supabase local. Use `supabase status --output json` for ANON_KEY and SERVICE_ROLE_KEY
# (plain `supabase status` shows sb_publishable_/sb_secret_ format; the JS client needs JWTs)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<ANON_KEY from supabase status --output json>
SUPABASE_SERVICE_ROLE_KEY=<SERVICE_ROLE_KEY from supabase status --output json>
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres?sslmode=disable
