{
  "css.validate": false,
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "json.schemas": [
    {
      "fileMatch": ["**/.oxlintrc.json"],
      "schema": {
        "type": "object",
        "additionalProperties": true
      }
    }
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always"
  }
}
